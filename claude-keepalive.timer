[Unit]
Description=Claude Code keepalive timer (weekdays, aligned to 5h windows)

[Timer]
# Asia/Kolkata (IST). Explicit TZ so it behaves the same if you travel/VPN.
# Schedule:
#   07:30 IST  -> window 1 runs 07:30 -> 12:30 (covers start of workday at 10:00)
#   12:25 IST  -> window 2 runs 12:25 -> 17:25 (fires 5 min before window 1 dies)
#   17:20 IST  -> window 3 runs 17:20 -> 22:20 (fires 5 min before window 2 dies)
OnCalendar=Mon..Fri *-*-* 07:30:00 Asia/Kolkata
OnCalendar=Mon..Fri *-*-* 12:25:00 Asia/Kolkata
OnCalendar=Mon..Fri *-*-* 17:20:00 Asia/Kolkata

# If the machine was off/asleep at fire time, run on next boot/resume.
Persistent=true
# Jitter so we don't hammer the API at the exact same second as other users.
RandomizedDelaySec=30s
Unit=claude-keepalive.service

[Install]
WantedBy=timers.target
